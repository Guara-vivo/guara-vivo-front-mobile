{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "jsx": "react-native",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext"
  },
  "include": [
    "App.tsx",
    "src/native/**/*.ts",
    "src/native/**/*.tsx"
  ],
  "exclude": [
    "src/app/**",
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
